@page "/"
@inject DecisionReportService ReportService
@implements IDisposable

<div class="dashboard">

    <div class="stats-row">
        <div class="stat-card stat-total @(_filterGroup == "ALL" ? "active" : "")" @onclick='() => SetFilterGroup("ALL")'>
            <span class="stat-value">@_all.Count</span>
            <span class="stat-label">Всего проверок</span>
        </div>
        <div class="stat-card status-valid @(_filterGroup == "VALID" ? "active" : "")" @onclick='() => SetFilterGroup("VALID")'>
            <span class="stat-value">@GetCount("VALID")</span>
            <span class="stat-label">Valid</span>
        </div>
        <div class="stat-card status-mismatch @(_filterGroup == "MISMATCH" ? "active" : "")" @onclick='() => SetFilterGroup("MISMATCH")'>
            <span class="stat-value">@GetCount("MISMATCH")</span>
            <span class="stat-label">Mismatch</span>
        </div>
        <div class="stat-card status-ambiguous @(_filterGroup == "AMBIGUOUS" ? "active" : "")" @onclick='() => SetFilterGroup("AMBIGUOUS")'>
            <span class="stat-value">@GetCount("AMBIGUOUS")</span>
            <span class="stat-label">Ambiguous</span>
        </div>
        <div class="stat-card status-no-ssn @(_filterGroup == "NO_DATA" ? "active" : "")" @onclick='() => SetFilterGroup("NO_DATA")'>
            <span class="stat-value">@(GetCount("NO_SSN") + GetCount("NO_DOCUMENTS_IN_DB"))</span>
            <span class="stat-label">No SSN / No docs</span>
        </div>
        <div class="stat-card status-invalid @(_filterGroup == "PROBLEM" ? "active" : "")" @onclick='() => SetFilterGroup("PROBLEM")'>
            <span class="stat-value">@(GetCount("INVALID") + GetCount("ERROR"))</span>
            <span class="stat-label">Invalid / Error</span>
        </div>
    </div>

    @if (_all.Count > 0)
    {
        <div class="status-bar" title="Распределение статусов">
            @foreach (var seg in StatusSegments)
            {
                <div class="status-bar-segment @seg.CssClass"
                     style="width:@(seg.WidthPercentCss)%"
                     title="@seg.Tooltip"></div>
            }
        </div>
    }

    @if (GetCount("MISMATCH") > 0)
    {
        <div class="mismatch-reasons">
            <span class="mismatch-reasons-label">Причины MISMATCH:</span>
            @foreach (var stat in MismatchFieldStats)
            {
                <span class="mismatch-chip @(_mismatchFieldFilter == stat.Field ? "active" : "")"
                      @onclick="() => SetMismatchFieldFilter(stat.Field)">
                    @stat.Label <b>@stat.Count</b>
                </span>
            }
            @if (_mismatchFieldFilter != null)
            {
                <span class="mismatch-clear" @onclick="ClearMismatchFieldFilter">✕ сбросить</span>
            }
        </div>
    }

    @if (_newSinceLastView > 0)
    {
        <div class="new-records-banner" @onclick="DismissNewBanner">
            <span>🆕 +@_newSinceLastView нов@(_newSinceLastView == 1 ? "ая запись" : "ых записей") с последнего просмотра</span>
            <span class="dismiss-hint">нажмите, чтобы скрыть</span>
        </div>
    }

    <div class="toolbar">
        <input class="search-input"
               placeholder="Поиск: PersonId, SSN, паспорт..."
               value="@_search"
               @oninput="OnSearchChanged" />

        <button class="refresh-btn" @onclick="Refresh">⟲ Обновить</button>

        <label class="auto-refresh-toggle">
            <input type="checkbox" checked="@_autoRefresh" @onchange="OnAutoRefreshChanged" />
            Авто-обновление
        </label>

        <span class="last-loaded">Обновлено: @_lastLoaded.ToString("HH:mm:ss")</span>
    </div>

    <div class="decision-list">
        @if (!_filteredCache.Any())
        {
            <div class="empty-state">Нет данных по заданным условиям.</div>
        }
        @foreach (var decision in PagedItems)
        {
            var isExpanded = _expanded.Contains(decision.PersonId);
            var statusClass = StatusPresentation.ToCssClass(decision.Status);
            var linkedCount = decision.LinkedPersonIds.Count(id => id != decision.PersonId);

            <div class="decision-card @statusClass">
                <div class="decision-header" @onclick="() => ToggleExpand(decision.PersonId)">
                    <div class="decision-person">
                        <a class="person-id"
                           href="@($"/person/{decision.PersonId}")"
                           @onclick:stopPropagation="true">#@((MarkupString)HighlightText(decision.PersonId.ToString()))</a>
                        <span class="status-badge @statusClass">
                            <span class="status-icon">@StatusPresentation.ToIcon(decision.Status)</span>
                            @decision.Status
                        </span>
                        @if (linkedCount > 0)
                        {
                            <span class="linked-badge"
                                  title="@($"Связан с PersonId: {string.Join(", ", decision.LinkedPersonIds.Where(id => id != decision.PersonId))}")">
                                🔗 @linkedCount
                            </span>
                        }
                    </div>

                    <div class="decision-summary">
                        @if (!string.IsNullOrWhiteSpace(decision.SelectedSsn))
                        {
                            <span class="ssn-value">SSN: @((MarkupString)HighlightText(decision.SelectedSsn))</span>
                        }
                        else if (decision.SsnCandidates.Count > 0)
                        {
                            <span class="ssn-candidates">Кандидаты: @string.Join(", ", decision.SsnCandidates)</span>
                        }
                        <span class="reason-text">@decision.Reason</span>
                    </div>

                    <span class="expand-icon">@(isExpanded ? "▲" : "▼")</span>
                </div>

                <div class="decision-body-wrapper @(isExpanded ? "expanded" : "")">
                    <div class="decision-body">
                        @if (decision.DbFirstName != null || decision.DbLastName != null || decision.DbBirthDate != null
                             || decision.MismatchedFields.Count > 0)
                        {
                            var bpr = GetBprIdentity(decision);
                            bool fMis = decision.MismatchedFields.Contains("FirstName");
                            bool lMis = decision.MismatchedFields.Contains("LastName");
                            bool dMis = decision.MismatchedFields.Contains("BirthDate");

                            <div class="identity-compare">
                                <div class="identity-col">
                                    <span class="identity-col-title">В базе (Persons)</span>
                                    <div class="identity-row @(fMis ? "field-mismatch" : "")">Имя: <b>@(decision.DbFirstName ?? "—")</b></div>
                                    <div class="identity-row @(lMis ? "field-mismatch" : "")">Фамилия: <b>@(decision.DbLastName ?? "—")</b></div>
                                    <div class="identity-row @(dMis ? "field-mismatch" : "")">Дата рождения: <b>@(decision.DbBirthDate?.ToString("dd.MM.yyyy") ?? "—")</b></div>
                                </div>
                                <div class="identity-arrow">⇄</div>
                                <div class="identity-col">
                                    <span class="identity-col-title">От BPR</span>
                                    <div class="identity-row @(fMis ? "field-mismatch" : "")">Имя: <b>@(bpr.First ?? "—")</b></div>
                                    <div class="identity-row @(lMis ? "field-mismatch" : "")">Фамилия: <b>@(bpr.Last ?? "—")</b></div>
                                    <div class="identity-row @(dMis ? "field-mismatch" : "")">Дата рождения: <b>@(bpr.Dob?.ToString("dd.MM.yyyy") ?? "—")</b></div>
                                </div>
                            </div>
                        }
                        <div class="checks-table-scroll">
                            <table class="checks-table">
                                <thead>
                                    <tr>
                                        <th>Паспорт</th>
                                        <th>SSN</th>
                                        <th>BPR Имя</th>
                                        <th>BPR Фамилия</th>
                                        <th>BPR ДР</th>
                                        <th title="Пересечение номеров документов — справочно, на решение не влияет">Документы (инфо)</th>
                                        <th>Ошибка</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var check in decision.Checks)
                                    {
                                        <tr>
                                            <td>@((MarkupString)HighlightText(check.Passport))</td>
                                            <td>@(check.Ssn ?? "—")</td>
                                            <td>@(check.BprFirstName ?? "—")</td>
                                            <td>@(check.BprLastName ?? "—")</td>
                                            <td>@(check.BprBirthDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                                            <td>
                                                <span class="match-icon @(check.DocumentsMatch ? "match-ok" : "match-fail")"
                                                      title="@($"DB: {string.Join(", ", check.DbDocuments)} | BPR: {(check.BprDocuments.Count > 0 ? string.Join(", ", check.BprDocuments) : "—")}")">
                                                    @(check.DocumentsMatch ? "✓" : "✗")
                                                </span>
                                            </td>
                                            <td class="error-cell">@(check.Error ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (TotalPages > 1)
        {
            <div class="pagination">
                <button class="page-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(_page - 1)">‹ Назад</button>
                <span class="page-info">Стр. @_page из @TotalPages · @_filteredCache.Count записей</span>
                <button class="page-btn" disabled="@(_page >= TotalPages)" @onclick="() => GoToPage(_page + 1)">Вперёд ›</button>
            </div>
        }
    </div>
</div>

@code {
    private const int PageSize = 25;

    private List<ValidationDecision> _all = [];
    private List<ValidationDecision> _filteredCache = [];
    private HashSet<long> _knownPersonIds = [];
    private int _newSinceLastView = 0;
    private bool _isFirstLoad = true;

    private string _search = "";
    private string _filterGroup = "ALL";
    private string? _mismatchFieldFilter;
    private readonly HashSet<long> _expanded = [];
    private Timer? _autoRefreshTimer;
    private bool _autoRefresh = true;
    private DateTime _lastLoaded = DateTime.Now;
    private int _page = 1;

    private static readonly HashSet<string> ProblemStatuses = ["INVALID", "ERROR"];
    private static readonly HashSet<string> NoDataStatuses = ["NO_SSN", "NO_DOCUMENTS_IN_DB"];

    private record StatusSegment(string CssClass, string Label, int Count, double Percent)
    {
        public string WidthPercentCss => Percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
        public string Tooltip => $"{Label}: {Count} ({Percent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}%)";
    }

    private record MismatchFieldStat(string Field, string Label, int Count);

    private IEnumerable<MismatchFieldStat> MismatchFieldStats
    {
        get
        {
            var mismatched = _all.Where(d => d.Status == "MISMATCH").ToList();
            if (mismatched.Count == 0)
                yield break;

            foreach (var field in new[] { "FirstName", "LastName", "BirthDate" })
            {
                var count = mismatched.Count(d => d.MismatchedFields.Contains(field));
                if (count == 0) continue;
                yield return new MismatchFieldStat(field, StatusPresentation.FieldLabel(field), count);
            }
        }
    }

    /// <summary>BPR's identity for a decision, taken from whichever check
    /// actually returned one — for a VALID/MISMATCH decision all checks for
    /// the matched SSN already agree with each other (see DecisionService),
    /// so any one of them is representative.</summary>
    private static (string? First, string? Last, DateTime? Dob) GetBprIdentity(ValidationDecision d)
    {
        var c = d.Checks.FirstOrDefault(x => x.BprFirstName != null || x.BprLastName != null || x.BprBirthDate != null);
        return (c?.BprFirstName, c?.BprLastName, c?.BprBirthDate);
    }

    protected override void OnInitialized()
    {
        Load(isAutoRefresh: false);

        _autoRefreshTimer = new Timer(
            _ =>
            {
                if (_autoRefresh)
                {
                    _ = InvokeAsync(() =>
                    {
                        Load(isAutoRefresh: true);
                        StateHasChanged();
                    });
                }
            },
            null,
            TimeSpan.FromSeconds(8),
            TimeSpan.FromSeconds(8));
    }

    private void Load(bool isAutoRefresh)
    {
        var fresh = ReportService.ReadAll();

        if (!_isFirstLoad)
        {
            var freshIds = fresh.Select(d => d.PersonId).ToHashSet();
            var newCount = freshIds.Except(_knownPersonIds).Count();
            if (isAutoRefresh && newCount > 0)
            {
                _newSinceLastView += newCount;
            }
        }

        _all = fresh;
        _knownPersonIds = fresh.Select(d => d.PersonId).ToHashSet();
        _lastLoaded = DateTime.Now;
        _isFirstLoad = false;

        RecomputeFiltered();
    }

    private void Refresh()
    {
        Load(isAutoRefresh: false);
        _newSinceLastView = 0;
    }

    private void DismissNewBanner() => _newSinceLastView = 0;

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _page = 1;
        RecomputeFiltered();
    }

    private void SetFilterGroup(string group)
    {
        _filterGroup = group;
        _mismatchFieldFilter = null;
        _page = 1;
        RecomputeFiltered();
    }

    private void SetMismatchFieldFilter(string field)
    {
        _filterGroup = "MISMATCH";
        _mismatchFieldFilter = _mismatchFieldFilter == field ? null : field;
        _page = 1;
        RecomputeFiltered();
    }

    private void ClearMismatchFieldFilter()
    {
        _mismatchFieldFilter = null;
        _page = 1;
        RecomputeFiltered();
    }

    private void OnAutoRefreshChanged(ChangeEventArgs e)
    {
        _autoRefresh = e.Value is bool b && b;
    }

    private bool MatchesGroup(ValidationDecision d)
    {
        var inGroup = _filterGroup switch
        {
            "ALL" => true,
            "VALID" => d.Status == "VALID",
            "MISMATCH" => d.Status == "MISMATCH",
            "AMBIGUOUS" => d.Status == "AMBIGUOUS",
            "NO_DATA" => NoDataStatuses.Contains(d.Status),
            "PROBLEM" => ProblemStatuses.Contains(d.Status),
            _ => true
        };

        if (!inGroup)
            return false;

        return _mismatchFieldFilter == null || d.MismatchedFields.Contains(_mismatchFieldFilter);
    }

    private void RecomputeFiltered()
    {
        _filteredCache = _all
            .Where(MatchesGroup)
            .Where(d =>
                string.IsNullOrWhiteSpace(_search) ||
                d.PersonId.ToString().Contains(_search) ||
                (d.SelectedSsn?.Contains(_search) ?? false) ||
                d.Checks.Any(c => c.Passport.Contains(_search, StringComparison.OrdinalIgnoreCase)))
            .OrderByDescending(d => d.PersonId)
            .ToList();

        var maxPage = Math.Max(1, (int)Math.Ceiling(_filteredCache.Count / (double)PageSize));
        if (_page > maxPage) _page = maxPage;
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_filteredCache.Count / (double)PageSize));

    private IEnumerable<ValidationDecision> PagedItems =>
        _filteredCache.Skip((_page - 1) * PageSize).Take(PageSize);

    private void GoToPage(int page)
    {
        _page = Math.Clamp(page, 1, TotalPages);
    }

    private int GetCount(string status) => _all.Count(d => d.Status == status);

    private IEnumerable<StatusSegment> StatusSegments
    {
        get
        {
            if (_all.Count == 0)
                yield break;

            var groups = new[]
            {
                ("status-valid", "Valid", GetCount("VALID")),
                ("status-mismatch", "Mismatch", GetCount("MISMATCH")),
                ("status-ambiguous", "Ambiguous", GetCount("AMBIGUOUS")),
                ("status-no-ssn", "No SSN/Docs", GetCount("NO_SSN") + GetCount("NO_DOCUMENTS_IN_DB")),
                ("status-invalid", "Invalid/Error", GetCount("INVALID") + GetCount("ERROR")),
            };

            foreach (var (cls, label, count) in groups)
            {
                if (count == 0) continue;
                yield return new StatusSegment(cls, label, count, count * 100.0 / _all.Count);
            }
        }
    }

    private string HighlightText(string? text)
    {
        text ??= "";
        var encoded = System.Net.WebUtility.HtmlEncode(text);

        if (string.IsNullOrWhiteSpace(_search))
            return encoded;

        var encodedSearch = System.Net.WebUtility.HtmlEncode(_search);
        var idx = encoded.IndexOf(encodedSearch, StringComparison.OrdinalIgnoreCase);
        if (idx < 0)
            return encoded;

        var before = encoded[..idx];
        var match = encoded.Substring(idx, encodedSearch.Length);
        var after = encoded[(idx + encodedSearch.Length)..];

        return $"{before}<mark class=\"search-highlight\">{match}</mark>{after}";
    }

    private void ToggleExpand(long personId)
    {
        if (!_expanded.Add(personId))
        {
            _expanded.Remove(personId);
        }
    }

    public void Dispose()
    {
        _autoRefreshTimer?.Dispose();
    }
}
